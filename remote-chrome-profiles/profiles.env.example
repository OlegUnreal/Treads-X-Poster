# Copy this file to profiles.env and edit the values.
#
# Format:
#   PROFILE_NAMES="ip1 ip2 ip3"
#   PROXY_<profile_name>="<scheme>://<host>:<port>"
#
# Supported proxy schemes in Chrome:
#   http://
#   https://
#   socks5://
#
# For username/password upstream proxies, use LOCAL_PROXY_<profile_name> for
# Chrome and UPSTREAM_PROXY_<profile_name> for the authenticated provider proxy.

PROFILE_NAMES="ip1 ip2 ip3"
PROFILE_LABEL_ip1="1 - ip1"
PROFILE_LABEL_ip2="2 - ip2"
PROFILE_LABEL_ip3="3 - ip3"

PROXY_ip1="http://127.0.0.1:11001"
PROXY_ip2="http://127.0.0.1:11002"
PROXY_ip3="http://127.0.0.1:11003"

UPSTREAM_PROXY_ip1="http://USERNAME:PASSWORD@PROXY_1_IP:PORT"
UPSTREAM_PROXY_ip2="http://USERNAME:PASSWORD@PROXY_2_IP:PORT"
UPSTREAM_PROXY_ip3="http://USERNAME:PASSWORD@PROXY_3_IP:PORT"

# Existing VNC/X11 display. Use :1 for a TigerVNC server started as vncserver :1.
VNC_DISPLAY=":1"

# Use false when a site must remember cookies, sign-in state, or age confirmation.
# Profiles are still isolated by separate Chrome user-data-dir folders.
INCOGNITO_MODE="false"
INCOGNITO_DOMAINS=""

# Some sites require one visible user gesture before video starts.
AUTO_CLICK_DOMAINS="pornhub.com"
AUTO_CLICK_DELAY_SECONDS="8"

# Optional page opened on start.
# Backend can override this per launch with LAUNCH_URL.
START_URL="profile-home"

WINDOW_SIZE="1000,760"
WINDOW_POSITION_ip1="20,20"
WINDOW_POSITION_ip2="120,80"
WINDOW_POSITION_ip3="220,140"
