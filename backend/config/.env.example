OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Optional default generation settings
POST_LANGUAGE=uk
POST_TOPIC=Behind The Smile
POST_TONE=warm, fan-friendly, concise
POST_COUNT=3

# Runtime storage
DATA_DIR=../generated
QUEUE_FILE=queue.jsonl
DRAFTS_FILE=posts.jsonl
X_LINKS_FILE=x-ready.html
CONTENT_PLAN_FILE=config/content-plan.json

# X API OAuth 2.0 user access token with post.write permission
X_ACCOUNT_LABEL=@your_x_account
X_ACCESS_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:3000/callback
X_SCOPES=tweet.read tweet.write users.read

# Alternative X OAuth 1.0a credentials
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN_SECRET=
X_REFRESH_TOKEN=
X_PUBLISH_MODE=selenium
X_BROWSER=chrome
X_BROWSER_PROFILE_DIR=../generated/selenium/chrome-profile
X_BROWSER_HEADLESS=false

# Threads API settings
THREADS_ACCOUNT_LABEL=@your_threads_account
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
META_APP_ID=
META_APP_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=http://127.0.0.1:3001/callback
