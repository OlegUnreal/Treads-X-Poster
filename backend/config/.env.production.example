OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Default generation settings
POST_LANGUAGE=uk
POST_TOPIC=Behind The Smile
POST_TONE=human, reflective, honest, concise
POST_COUNT=3

# Persistent server storage. Point this to a backed-up folder or mounted volume.
DATA_DIR=/opt/behind-the-smile/data
QUEUE_FILE=queue.jsonl
DRAFTS_FILE=posts.jsonl
X_LINKS_FILE=x-ready.html
CONTENT_PLAN_FILE=/opt/behind-the-smile/config/content-plan.json
ACTIVE_ACCOUNT_FILE=active-account.txt

# Optional multi-account setup. Keep each X browser profile separate.
# SOCIAL_ACCOUNTS=main,second
# ACCOUNT_MAIN_LABEL=Main Behind The Smile
# ACCOUNT_MAIN_X_ACCOUNT_LABEL=@your_main_x_account
# ACCOUNT_MAIN_X_PUBLISH_MODE=selenium
# ACCOUNT_MAIN_X_BROWSER_PROFILE_DIR=/opt/behind-the-smile/data/selenium/main-chrome-profile
# ACCOUNT_MAIN_THREADS_ACCOUNT_LABEL=@your_main_threads_account
# ACCOUNT_MAIN_THREADS_ACCESS_TOKEN=
# ACCOUNT_MAIN_THREADS_USER_ID=
# ACCOUNT_SECOND_LABEL=Second project
# ACCOUNT_SECOND_X_ACCOUNT_LABEL=@your_second_x_account
# ACCOUNT_SECOND_X_PUBLISH_MODE=selenium
# ACCOUNT_SECOND_X_BROWSER_PROFILE_DIR=/opt/behind-the-smile/data/selenium/second-chrome-profile
# ACCOUNT_SECOND_THREADS_ACCOUNT_LABEL=@your_second_threads_account
# ACCOUNT_SECOND_THREADS_ACCESS_TOKEN=
# ACCOUNT_SECOND_THREADS_USER_ID=

# X posting through Selenium browser automation
X_ACCOUNT_LABEL=
X_PUBLISH_MODE=selenium
X_BROWSER=chrome
X_BROWSER_PROFILE_DIR=/opt/behind-the-smile/data/selenium/chrome-profile
X_BROWSER_HEADLESS=false

# Optional X API credentials. Selenium posting can work without these.
X_ACCESS_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:3000/callback
X_SCOPES=tweet.read tweet.write users.read
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN_SECRET=
X_REFRESH_TOKEN=

# Threads API settings
THREADS_ACCOUNT_LABEL=
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
META_APP_ID=
META_APP_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=http://127.0.0.1:3001/callback
